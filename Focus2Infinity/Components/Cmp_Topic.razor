@using Focus2Infinity.Services
@using Focus2Infinity
@inject ImageCatalogService imageCatalogService
@inject IStringLocalizer<SharedResource> L

<div class="text-center" style="margin: 50px 10px; position: relative;">
  <h3>@L[Topic]</h3>
</div>

@if (images == null)
{
  <h5>Loading...</h5>
}
else
{
  for (int i = 0; i < images.Count; i++)
  {
    <div class="row" style="margin: 50px 10px;">
      <Cmp_ImgStory Topic=@Topic Name=@GetImg(i) />
    </div>
  }
}

@code {
  [Parameter]
  public string Topic { get; set; }
  List<string> images;
  string GetImg(int i) => $"{images[i]}";

  protected override async Task OnInitializedAsync()
  {
    images = await imageCatalogService.GetSubTopicsSorted(Topic, L);
  }
}