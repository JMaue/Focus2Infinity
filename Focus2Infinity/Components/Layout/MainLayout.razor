@using System.Globalization
@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> L

<div class="container-fluid h-100 d-flex flex-column">
  <div class="row">
    <img src="img/title3.jpg" alt="Image" class="img-fluid">
    <div class="col-1" style="background-color:black">
      <NavMenu />
    </div>
  </div>
  <div class="row flex-grow-1">
    <div class="col-12 p-0">
      @Body
    </div>
  </div>
  <footer class="row mt-auto">
    <div class="col-12 bg-dark text-white py-2">
      <div class="container">
        <div class="d-flex justify-content-between align-items-center flex-wrap small">
          <div class="mb-1 mb-md-0">
            <span class="text-muted" style="font-size:0.75rem">© @DateTime.Now.Year Focus to Infinity</span>
          </div>
          <div>
            <a href="/aboutMe" class="text-white text-decoration-none">@L["About Me"]</a>
          </div>
          <div class="d-flex gap-2" style="font-size:0.75rem">
            <a href="/impressum" class="text-white text-decoration-none">@L["Impressum"]</a>
            <a href="/datenschutz" class="text-white text-decoration-none">@L["Datenschutz"]</a>
          </div>
        </div>
      </div>
    </div>
  </footer>
</div>

<Cmp_CookieConsent />