@using Focus2Infinity.Data
@using Focus2Infinity.Services
@using Focus2Infinity
@inject ImageMetadataService imageMetadataService

@if (_source != null)
{
  <Cmp_ImageCard Topic=@Topic Src=@Src />
  <a href=@details style="color:azure; text-decoration: none;"><span>@Headline</span> </a>
}
else
{
  <p>L[Loading]</p>
}

@code {
  [Parameter]
  public string Topic { get; set; }

  [Parameter]
  public string Src { get; set; }

  private ImageStory? _source = null;
  private string Headline => _source?.GetHeadline ();
  string details => $"/imagedetails/{Topic}/{Src}";

  private string Unwrap(string value) => imageMetadataService.Unwrap(value);

  protected override async Task OnInitializedAsync()
  {
    _source = await imageMetadataService.GetStoryText(Topic, Src);
  }
}
